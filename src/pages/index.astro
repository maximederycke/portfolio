---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Maxime Derycke — Développeur Fullstack JS/TS">
  <section class="max-w-3xl mx-auto px-6 py-28">

    <p class="text-sm font-mono text-teal-500 mb-5">Disponible pour de nouvelles missions</p>

    <h1 class="text-4xl font-semibold text-zinc-900 leading-tight mb-4">
      Maxime Derycke
    </h1>
    <p class="text-xl text-zinc-500 mb-6">
      Développeur Fullstack JS/TS freelance
    </p>
    <p class="text-base text-zinc-500 leading-relaxed max-w-lg mb-12">
      Je conçois et développe des applications web sur-mesure — de la réflexion UX
      jusqu'au déploiement. Full remote, basé à Beauvais.
    </p>

    <div class="flex items-center justify-between">
      <a
        href="/contact"
        class="px-5 py-2.5 bg-zinc-900 text-white text-sm font-medium rounded-lg hover:bg-zinc-700 transition-colors"
      >
        Démarrer un projet
      </a>

      <div class="flex items-center gap-5">
        <a
          href="https://www.linkedin.com/in/maximederycke"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="text-zinc-400 hover:text-zinc-600 transition-colors"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
        </a>

        <a
          href="https://www.malt.fr/profile/maximederycke"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Malt"
          class="text-zinc-400 hover:text-zinc-600 transition-colors"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19.59 10.41L13.59 4.41C13.21 4.03 12.7 3.82 12.17 3.82C11.64 3.82 11.13 4.03 10.75 4.41L9.34 5.82L11.46 7.94C11.69 7.87 11.93 7.82 12.17 7.82C13.27 7.82 14.17 8.72 14.17 9.82C14.17 10.06 14.12 10.3 14.05 10.53L16.17 12.65C16.24 12.42 16.29 12.18 16.29 11.94C16.29 11.41 16.08 10.9 15.7 10.53L19.59 10.41ZM12.17 11.82C11.07 11.82 10.17 10.92 10.17 9.82C10.17 9.58 10.22 9.34 10.29 9.11L8.17 6.99C8.1 7.22 8.05 7.46 8.05 7.7C8.05 8.23 8.26 8.74 8.64 9.11L4.41 13.34C4.03 13.72 3.82 14.23 3.82 14.76C3.82 15.29 4.03 15.8 4.41 16.18L10.41 22.18C10.79 22.56 11.3 22.77 11.83 22.77C12.36 22.77 12.87 22.56 13.25 22.18L14.66 20.77L12.54 18.65C12.31 18.72 12.07 18.77 11.83 18.77C10.73 18.77 9.83 17.87 9.83 16.77C9.83 16.53 9.88 16.29 9.95 16.06L7.83 13.94C7.76 14.17 7.71 14.41 7.71 14.65C7.71 15.18 7.92 15.69 8.3 16.06L4.07 16.18L12.17 11.82Z"/>
          </svg>
        </a>

        <a
          href="https://github.com/maximederycke"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="text-zinc-400 hover:text-zinc-600 transition-colors"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      </div>
    </div>

  </section>
</BaseLayout>
