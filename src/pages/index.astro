---
import BaseLayout from '../layouts/BaseLayout.astro'
import LinkedIn from '../components/icons/LinkedIn.astro'
import Malt from '../components/icons/Malt.astro'
import GitHub from '../components/icons/GitHub.astro'
---

<BaseLayout title="Maxime Derycke — Développeur Fullstack JS/TS">
  <div class="relative isolate">

    <!-- Grille SVG — remonte derrière le header fixe -->
    <svg
      aria-hidden="true"
      class="absolute inset-x-0 -top-20 -z-10 h-224 w-full mask-[radial-gradient(20rem_20rem_at_60%_40%,white,transparent)] sm:mask-[radial-gradient(40rem_40rem_at_60%_40%,white,transparent)] stroke-zinc-200"
    >
      <defs>
        <pattern id="grid" width="200" height="200" x="50%" y="-1" patternUnits="userSpaceOnUse">
          <path d="M.5 200V.5H200" fill="none" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" stroke-width="0" />
    </svg>

    <!-- Blob teal -->
    <div
      aria-hidden="true"
      class="absolute top-0 right-0 left-1/2 -z-10 -ml-24 transform-gpu overflow-hidden blur-3xl lg:ml-24 xl:ml-48"
    >
      <div
        style="clip-path: polygon(63.1% 29.5%, 100% 17.1%, 76.6% 3%, 48.4% 0%, 44.6% 4.7%, 54.5% 25.3%, 59.8% 49%, 55.2% 57.8%, 44.4% 57.2%, 27.8% 47.9%, 35.1% 81.5%, 0% 97.7%, 39.2% 100%, 35.2% 81.4%, 97.2% 52.8%, 63.1% 29.5%)"
        class="aspect-801/1036 w-[34rem] bg-linear-to-tr from-teal-200 to-teal-400 opacity-25"
      ></div>
    </div>

    <div>
      <div class="mx-auto max-w-7xl px-6 pt-24 pb-32 sm:pt-32 lg:px-8 lg:pt-36">
        <div class="mx-auto max-w-2xl gap-x-14 lg:mx-0 lg:flex lg:max-w-none lg:items-center">

          <!-- Texte gauche -->
          <div class="relative w-full lg:max-w-xl lg:shrink-0 xl:max-w-2xl">
            <p class="text-sm font-mono text-teal-500 mb-5">Disponible pour de nouvelles missions</p>
            <h1 class="text-5xl font-semibold tracking-tight text-zinc-900 sm:text-6xl">
              Développeur<br />Fullstack JS/TS
            </h1>
            <p class="mt-4 text-xl text-zinc-500">
              Freelance · Remote first
            </p>
            <p class="mt-6 text-base text-zinc-500 leading-relaxed sm:max-w-md lg:max-w-none">
              Je conçois et développe des applications web sur-mesure — de la réflexion UX
              jusqu'au déploiement. Basé à Beauvais.
            </p>
            <div class="mt-10 flex items-center gap-8">
              <a
                href="/contact"
                class="px-5 py-2.5 bg-zinc-900 text-white text-sm font-medium rounded-lg hover:bg-zinc-700 transition-colors"
              >
                Démarrer un projet
              </a>
              <div class="flex items-center gap-5">
                <a href="https://www.linkedin.com/in/maximederycke" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-zinc-400 hover:text-zinc-600 transition-colors">
                  <LinkedIn size={20} />
                </a>
                <a href="https://www.malt.fr/profile/maximederycke" target="_blank" rel="noopener noreferrer" aria-label="Malt" class="text-zinc-400 hover:text-zinc-600 transition-colors">
                  <Malt size={20} />
                </a>
                <a href="https://github.com/maximederycke" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="text-zinc-400 hover:text-zinc-600 transition-colors">
                  <GitHub size={20} />
                </a>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>

  </div>

  <!-- Chiffres clés -->
  <div class="mx-auto max-w-7xl px-6 lg:px-8 py-16 sm:py-20">
    <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-none">
      <h2 class="text-3xl font-semibold tracking-tight text-zinc-900 mb-10">Maxime Derycke</h2>
      <div class="flex flex-col gap-x-8 gap-y-16 lg:flex-row">
        <div class="lg:w-full lg:max-w-2xl lg:flex-auto">
          <p class="text-xl text-zinc-600 leading-relaxed">
            Je prends en charge des projets web de bout en bout — de la conception UX
            à la mise en production — avec une vraie attention portée à la qualité du code
            et à l'expérience utilisateur.
          </p>
          <p class="mt-6 text-base text-zinc-500 leading-relaxed max-w-xl">
            Basé à Beauvais, je travaille en remote avec des clients partout en France.
            Disponible pour des déplacements ponctuels en Île-de-France et Hauts-de-France.
            Réactif, transparent sur l'avancement, et impliqué au-delà du seul périmètre technique.
          </p>
        </div>
        <div class="lg:flex lg:flex-auto lg:justify-center">
          <dl class="w-64 space-y-8 xl:w-72">
            <div class="flex flex-col-reverse gap-y-1">
              <dt class="text-sm text-zinc-500">D'expérience en développement web</dt>
              <dd class="text-5xl font-semibold tracking-tight text-zinc-900">4 ans</dd>
            </div>
            <div class="flex flex-col-reverse gap-y-1">
              <dt class="text-sm text-zinc-500">Délai de réponse garanti</dt>
              <dd class="text-5xl font-semibold tracking-tight text-zinc-900">48h</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </div>

  <!-- Services en bref -->
  <section class="mx-auto max-w-7xl px-6 lg:px-8 py-16">
    <div class="flex items-baseline justify-between mb-8">
      <h2 class="text-xl font-semibold text-zinc-900">Comment je travaille</h2>
      <a href="/services" class="text-sm text-zinc-400 hover:text-zinc-600 transition-colors">Voir les services →</a>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div class="border border-zinc-200 rounded-2xl p-6">
        <span class="text-xs font-mono text-zinc-400 uppercase tracking-widest">Agile</span>
        <p class="text-sm text-zinc-500 leading-relaxed mt-3">
          TJM fixe, sprints de 2 semaines. Idéal si le périmètre évolue — on ajuste les priorités à chaque cycle.
        </p>
      </div>

      <div class="border border-zinc-200 rounded-2xl p-6 bg-zinc-50">
        <span class="text-xs font-mono text-zinc-400 uppercase tracking-widest">Forfait</span>
        <p class="text-sm text-zinc-500 leading-relaxed mt-3">
          Périmètre et prix fixés en amont. Idéal si vous avez besoin de visibilité budgétaire sur une mission définie.
        </p>
      </div>
    </div>
  </section>

</BaseLayout>
