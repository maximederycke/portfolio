---
import '../styles/global.css'
import SocialLinks from '../components/SocialLinks.astro'

interface Props {
  title: string
  description?: string
}

const { title, description = 'Développeur Fullstack JS/TS freelance' } = Astro.props

const navLinks = [
  { href: '/about', label: 'À propos' },
  { href: '/services', label: 'Services' },
  { href: '/contact', label: 'Contact' },
]

const currentPath = Astro.url.pathname
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <title>{title}</title>
  </head>
  <body class="bg-white text-zinc-900 min-h-screen flex flex-col">

    <header class="fixed inset-x-0 top-0 z-10 pt-5 pb-2 flex justify-center px-6 pointer-events-none">

      <!-- Nav desktop : pill complète -->
      <nav class="hidden sm:flex items-center gap-1 bg-white/90 backdrop-blur border border-zinc-200 rounded-full px-3 shadow-sm text-sm pointer-events-auto">
        <a
          href="/"
          class:list={[
            'relative px-3 py-2 font-medium transition',
            currentPath === '/' ? 'text-teal-500' : 'text-zinc-500 hover:text-teal-500',
          ]}
        >
          Maxime
          {currentPath === '/' && (
            <span class="absolute inset-x-1 -bottom-px h-px bg-linear-to-r from-teal-500/0 via-teal-500/40 to-teal-500/0" />
          )}
        </a>
        <span class="w-px h-4 bg-zinc-200 mx-1"></span>
        {navLinks.map(({ href, label }) => {
          const isActive = currentPath.startsWith(href)
          return (
            <a
              href={href}
              class:list={[
                'relative px-3 py-2 transition',
                isActive ? 'text-teal-500' : 'text-zinc-500 hover:text-teal-500',
              ]}
            >
              {label}
              {isActive && (
                <span class="absolute inset-x-1 -bottom-px h-px bg-linear-to-r from-teal-500/0 via-teal-500/40 to-teal-500/0" />
              )}
            </a>
          )
        })}
      </nav>

      <!-- Nav mobile : pill compacte + hamburger -->
      <div class="sm:hidden flex items-center justify-between w-full bg-white/90 backdrop-blur border border-zinc-200 rounded-full px-4 py-2.5 shadow-sm pointer-events-auto">
        <a
          href="/"
          class:list={[
            'text-sm font-medium transition-colors',
            currentPath === '/' ? 'text-zinc-900' : 'text-zinc-500',
          ]}
        >
          Maxime Derycke
        </a>
        <button
          id="menu-toggle"
          aria-label="Ouvrir le menu"
          aria-expanded="false"
          class="text-zinc-500 p-1 -mr-1"
        >
          <svg id="icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
          <svg id="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>

      <!-- Dropdown mobile -->
      <div
        id="mobile-menu"
        class="sm:hidden hidden absolute top-full mt-2 w-[calc(100%-3rem)] bg-white border border-zinc-200 rounded-2xl shadow-md p-2 pointer-events-auto"
      >
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'block px-4 py-2.5 rounded-xl text-sm transition-colors border-l-2',
              currentPath.startsWith(href)
                ? 'text-zinc-900 font-medium border-teal-500 bg-zinc-50'
                : 'text-zinc-600 border-transparent hover:bg-zinc-50 hover:text-zinc-900',
            ]}
          >
            {label}
          </a>
        ))}
      </div>

    </header>

    <main class="flex-1 pt-16">
      <slot />
    </main>

    <footer class="border-t border-zinc-100 py-8">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 flex items-center justify-between">
        <p class="text-xs font-mono text-zinc-400">
          © {new Date().getFullYear()} Maxime Derycke
        </p>
        <SocialLinks size={18} />
      </div>
    </footer>

  </body>
</html>

<script>
  const toggle = document.getElementById('menu-toggle')
  const menu = document.getElementById('mobile-menu')
  const iconOpen = document.getElementById('icon-open')
  const iconClose = document.getElementById('icon-close')

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden')
    menu?.classList.toggle('hidden', isOpen)
    iconOpen?.classList.toggle('hidden', !isOpen)
    iconClose?.classList.toggle('hidden', isOpen)
    toggle.setAttribute('aria-expanded', String(!isOpen))
  })

  // Ferme le menu au clic sur un lien
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden')
      iconOpen?.classList.remove('hidden')
      iconClose?.classList.add('hidden')
      toggle?.setAttribute('aria-expanded', 'false')
    })
  })
</script>
